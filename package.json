{
  "name": "@jcodesmore/agent-recall",
  "version": "0.4.0",
  "description": "Local cross-agent conversation recall for Claude Code, Codex, and OpenCode.",
  "type": "module",
  "private": true,
  "bin": {
    "agent-recall": "./scripts/recall.mjs"
  },
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "recall": "node ./scripts/recall.mjs",
    "sync": "node ./scripts/recall.mjs sync",
    "doctor": "node ./scripts/recall.mjs doctor",
    "install-skill": "node ./scripts/install.mjs",
    "test": "node --test test/*.test.mjs",
    "test:watch": "node --test --watch test/*.test.mjs"
  },
  "files": [
    ".claude-plugin",
    "SKILL.md",
    "skills",
    "hooks",
    "scripts",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/JCodesMore/claude-search",
  "repository": {
    "type": "git",
    "url": "https://github.com/JCodesMore/claude-search.git"
  },
  "keywords": [
    "agent-skills",
    "claude-code",
    "codex",
    "opencode",
    "conversation-search",
    "session-history",
    "local-first"
  ],
  "license": "Apache-2.0"
}
